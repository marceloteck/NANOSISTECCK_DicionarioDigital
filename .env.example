APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

SEO_SITE_NAME="${APP_NAME}"
SEO_SITE_SHORT_NAME="${APP_NAME}"
SEO_BASE_URL="${APP_URL}"
SEO_TITLE_DEFAULT="${APP_NAME}"
SEO_TITLE_SEPARATOR=" | "
SEO_DESCRIPTION_DEFAULT=
SEO_KEYWORDS_DEFAULT=
SEO_LANGUAGE=pt-BR
SEO_LOCALE=pt-br
SEO_CHARSET=utf-8
SEO_AUTHOR=
SEO_PUBLISHER=
SEO_THEME_COLOR=#111827
SEO_BACKGROUND_COLOR=#ffffff
SEO_FAVICON=/favicon.svg
SEO_DEFAULT_IMAGE=/images/seo/default.jpg
SEO_TWITTER_SITE=
SEO_TWITTER_CREATOR=
SEO_TWITTER_CARD=summary_large_image
SEO_SOCIAL_LINKS=
SEO_ORGANIZATION_NAME="${APP_NAME}"
SEO_ORGANIZATION_LOGO=/images/seo/logo.png
SEO_ORGANIZATION_URL="${APP_URL}"
SEO_ORGANIZATION_SAME_AS=
SEO_ORGANIZATION_CONTACT_EMAIL=
SEO_ORGANIZATION_CONTACT_PHONE=
SEO_ORGANIZATION_CONTACT_TYPE="customer support"
SEO_INDEXATION_ENABLED=true
SEO_INDEXATION_ALLOW_IN_ENV=production
SEO_ROBOTS_DISALLOW_PATHS=/login,/admin,/dashboard,/api,/storage,/vendor
SEO_ROBOTS_ALLOW_PATHS=/
SEO_ADSENSE_ENABLED=true
SEO_ADSENSE_SHOW_ADS_ONLY_IN_ENV=production
SEO_ADSENSE_REQUIRE_INDEXABLE_PAGE=true
SEO_ADSENSE_LAYOUT_STYLE=clean
